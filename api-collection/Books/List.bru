meta {
  name: List books
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/books
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("returns an array of books", function () {
    expect(res.status).to.equal(200);
    expect(res.body).to.have.property("books").that.is.an("array");
  });
}
